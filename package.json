{
  "name": "fixyz-mob",
  "version": "0.1.0",
  "private": true,
  "description": "FIXYZ mobile foundation scaffold",
  "type": "module",
  "scripts": {
    "android": "bash ./scripts/run-android.sh",
    "ios": "DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer react-native run-ios --port 8088 --simulator \"${IOS_SIMULATOR:-iPhone 17}\"",
    "start": "react-native start --port 8088",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live:auth": "vitest run tests/e2e/mobile-auth-live.e2e.test.ts",
    "e2e:maestro:auth": "bash ./scripts/run-maestro-auth-suite.sh",
    "e2e:maestro:order": "bash ./scripts/run-maestro-auth-suite.sh ./e2e/maestro/order",
    "test:collab-webhook": "node --test tests/collab-webhook/*.test.js",
    "test:supply-chain": "node --test tests/supply-chain/*.test.cjs",
    "lint:collab-webhook": "node --check .github/scripts/collab-webhook/*.js",
    "lint:supply-chain": "node --check .github/scripts/supply-chain/security-utils.cjs && node --check .github/scripts/supply-chain/run-security-baseline.cjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "bundle:dry-run": "mkdir -p .tmp/assets && react-native bundle --platform ios --dev true --entry-file index.js --bundle-output .tmp/main.jsbundle --assets-dest .tmp/assets --reset-cache",
    "ci-mobile": "npm run typecheck && npm run lint && npm run test && npm run bundle:dry-run",
    "prepare": "husky"
  },
  "dependencies": {
    "@react-native-cookies/cookies": "^6.2.1",
    "react": "19.2.4",
    "react-native": "0.84.0",
    "react-native-keychain": "^10.0.0",
    "react-native-launch-arguments": "^4.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@react-native-community/cli": "^20.1.2",
    "@react-native/babel-preset": "0.84.0",
    "@react-native/metro-config": "0.84.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-test-renderer": "^19.1.0",
    "esbuild": "^0.27.0",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "react-test-renderer": "^19.2.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vitest": "^4.0.8"
  }
}
